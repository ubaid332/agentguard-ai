# Copy this file to .env and fill in your Anthropic API key.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# SQLite audit log location (relative to project root)
AGENTGUARD_DB_PATH=agentguard.db

# Base URL the Streamlit UI uses to reach the FastAPI backend
AGENTGUARD_API_URL=http://localhost:8000
